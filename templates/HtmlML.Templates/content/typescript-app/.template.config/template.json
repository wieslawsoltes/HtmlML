{
  "$schema": "http://json.schemastore.org/template",
  "author": "HtmlML",
  "classifications": ["Desktop", "Avalonia", "TypeScript", "React"],
  "identity": "HtmlML.Templates.TypeScriptApp",
  "name": "HtmlML primarily TypeScript desktop application",
  "shortName": "htmlml-typescript",
  "sourceName": "HtmlMLTypeScriptApp",
  "preferNameDirectory": true,
  "symbols": {
    "htmlmlVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "11.3.4-alpha.3",
      "replaces": "HTMLML_PACKAGE_VERSION"
    }
  },
  "primaryOutputs": [{ "path": "HtmlMLTypeScriptApp.csproj" }]
}
