{
  "schemaVersion": "1.0",
  "id": "dev.htmlml.typescript-app",
  "displayName": "HtmlML TypeScript Desktop",
  "version": "1.0.0",
  "profileVersion": "1.0",
  "entryPoint": "src/main.tsx",
  "assets": [
    "src/main.tsx"
  ],
  "capabilities": [
    "dom",
    "css.layout",
    "canvas.2d",
    "svg",
    "input.pointer",
    "input.keyboard",
    "input.focus",
    "host.settings",
    "host.notifications"
  ],
  "lifecycle": {
    "mountExport": "mount",
    "unmountExport": "unmount"
  }
}
