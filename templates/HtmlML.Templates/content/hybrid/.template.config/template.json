{
  "$schema": "http://json.schemastore.org/template",
  "author": "HtmlML",
  "classifications": ["Desktop", "Avalonia", "Hybrid", "React"],
  "identity": "HtmlML.Templates.Hybrid",
  "name": "HtmlML hybrid Avalonia and React application",
  "shortName": "htmlml-hybrid",
  "sourceName": "HtmlMLHybrid",
  "preferNameDirectory": true,
  "symbols": {
    "htmlmlVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "11.3.4-alpha.3",
      "replaces": "HTMLML_PACKAGE_VERSION"
    }
  },
  "primaryOutputs": [{ "path": "HtmlMLHybrid.csproj" }]
}
