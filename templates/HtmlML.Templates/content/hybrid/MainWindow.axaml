<Window x:Class="HtmlMLHybrid.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sdk="clr-namespace:HtmlML.Sdk.Avalonia;assembly=HtmlML.Sdk.Avalonia"
        Width="1000" Height="680" Title="HtmlML Hybrid React Islands">
  <Grid ColumnDefinitions="220,*,*" Margin="16">
    <StackPanel Spacing="12"><TextBlock Text="Native Avalonia shell" FontSize="22"/><Button Content="Native command"/><TextBlock Text="Two isolated React roots share immutable caches." TextWrapping="Wrap"/></StackPanel>
    <sdk:HtmlMlComponentHost x:Name="PrimaryHost" Grid.Column="1" Margin="12,0" PackagePath="Component" AutoMount="False" />
    <sdk:HtmlMlComponentHost x:Name="SecondaryHost" Grid.Column="2" PackagePath="Component" AutoMount="False" />
  </Grid>
</Window>
