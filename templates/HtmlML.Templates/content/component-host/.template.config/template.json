{
  "$schema": "http://json.schemastore.org/template",
  "author": "HtmlML",
  "classifications": ["Desktop", "Avalonia", "React", "TypeScript"],
  "identity": "HtmlML.Templates.ComponentHost",
  "name": "HtmlML React component host",
  "shortName": "htmlml-component-host",
  "sourceName": "HtmlMLComponentHost",
  "preferNameDirectory": true,
  "symbols": {
    "htmlmlVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "11.3.4-alpha.3",
      "replaces": "HTMLML_PACKAGE_VERSION"
    }
  },
  "primaryOutputs": [{ "path": "HtmlMLComponentHost.csproj" }]
}
