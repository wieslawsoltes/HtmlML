<Window x:Class="HtmlMLComponentHost.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sdk="clr-namespace:HtmlML.Sdk.Avalonia;assembly=HtmlML.Sdk.Avalonia"
        Width="1000" Height="680" Title="HtmlML Component Host">
  <sdk:HtmlMlComponentHost x:Name="PrimaryHost" PackagePath="Component" AutoMount="False" Margin="16" />
</Window>
