+            ASSERT_EVAL(FROM_MAYBE(m_hContext->Global()->Set(m_hContext, CreateString("__htmlMlNativeWriteDomRect"), FROM_MAYBE(v8::Function::New(m_hContext, HtmlMlWriteDomRectCallback, hContextImpl)))));
 
