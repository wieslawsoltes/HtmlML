 // support for v8::Maybe and v8::MaybeLocal
@@ -372,6 +373,70 @@ constexpr enum class DummyCallbackStatus {} t_CallbackStatus {};
 //-----------------------------------------------------------------------------
 
 static std::atomic<size_t> s_InstanceCount(0);
+static std::atomic<V8ContextImpl::HtmlMlReadDomNumericPropertyMethod*> s_pHtmlMlReadDomNumericProperty(nullptr);
+static std::atomic<V8ContextImpl::HtmlMlWriteDomRectMethod*> s_pHtmlMlWriteDomRect(nullptr);
+
+//-----------------------------------------------------------------------------
+
+bool V8ContextImpl::RegisterHtmlMlTypedManagedAbi(int32_t version, void* pvReadDomNumericProperty, void* pvWriteDomRect) noexcept
+{
+    if ((version != 1) || (pvReadDomNumericProperty == nullptr) || (pvWriteDomRect == nullptr))
+    {
+        return false;
+    }
+
+    s_pHtmlMlReadDomNumericProperty.store(
+        reinterpret_cast<HtmlMlReadDomNumericPropertyMethod*>(pvReadDomNumericProperty),
+        std::memory_order_release);
+    s_pHtmlMlWriteDomRect.store(
+        reinterpret_cast<HtmlMlWriteDomRectMethod*>(pvWriteDomRect),
+        std::memory_order_release);
+    return true;
+}
+
+//-----------------------------------------------------------------------------
+
+void V8ContextImpl::HtmlMlReadDomNumericPropertyCallback(const v8::FunctionCallbackInfo<v8::Value>& info)
+{
+    auto pCallback = s_pHtmlMlReadDomNumericProperty.load(std::memory_order_acquire);
+    if ((pCallback == nullptr) || (info.Length() < 2))
+    {
+        info.GetReturnValue().Set(v8::Number::New(info.GetIsolate(), std::numeric_limits<double>::quiet_NaN()));
+        return;
+    }
+
+    auto hContext = info.GetIsolate()->GetCurrentContext();
+    auto nodeId = info[0]->IntegerValue(hContext).FromMaybe(0);
+    auto property = info[1]->Int32Value(hContext).FromMaybe(-1);
+    info.GetReturnValue().Set(v8::Number::New(info.GetIsolate(), pCallback(nodeId, property)));
+}
+
+//-----------------------------------------------------------------------------
+
+void V8ContextImpl::HtmlMlWriteDomRectCallback(const v8::FunctionCallbackInfo<v8::Value>& info)
+{
+    auto pCallback = s_pHtmlMlWriteDomRect.load(std::memory_order_acquire);
+    if ((pCallback == nullptr) || (info.Length() < 3) || !info[2]->IsFloat64Array())
+    {
+        info.GetReturnValue().Set(false);
+        return;
+    }
+
+    auto hArray = info[2].As<v8::Float64Array>();
+    if (hArray->Length() < 8)
+    {
+        info.GetReturnValue().Set(false);
+        return;
+    }
+
+    auto hContext = info.GetIsolate()->GetCurrentContext();
+    auto nodeId = info[0]->IntegerValue(hContext).FromMaybe(0);
+    auto kind = info[1]->Int32Value(hContext).FromMaybe(-1);
+    auto spBackingStore = hArray->Buffer()->GetBackingStore();
+    auto pValues = reinterpret_cast<double*>(
+        static_cast<uint8_t*>(spBackingStore->Data()) + hArray->ByteOffset());
+    info.GetReturnValue().Set(pCallback(nodeId, kind, pValues) != 0);
+}
 
 //-----------------------------------------------------------------------------
 
