{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://htmlml.dev/schemas/backend-capabilities-1.0.json",
  "title": "HtmlML backend capability manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "displayName",
    "version",
    "assembly",
    "backendType",
    "maximumSupportLevel",
    "capabilities",
    "targetFrameworks"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "assembly": { "type": "string", "minLength": 1 },
    "backendType": { "type": "string", "minLength": 1 },
    "maximumSupportLevel": {
      "enum": ["Experimental", "Component", "Application", "Advanced"]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "DomProjection", "CssLayout", "Canvas2D", "Svg", "Images",
          "PointerInput", "KeyboardInput", "TextInput", "Focus", "Clipboard",
          "Accessibility", "DragDrop", "InputMethodEditor", "OpenGl", "WebGpu"
        ]
      }
    },
    "targetFrameworks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "platforms": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
