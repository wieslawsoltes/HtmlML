<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <Description>Component manifests, compatibility checks, diagnostics, lifecycle, and host bridge contracts for HtmlML applications.</Description>
    <PackageId>HtmlML.Sdk</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>htmlml;react;typescript;sdk;components;host-bridge</PackageTags>
    <RepositoryUrl>https://github.com/wieslawsoltes/HtmlML</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\HtmlML.Core\HtmlML.Core.csproj" />
    <ProjectReference Include="..\HtmlML.JavaScript\HtmlML.JavaScript.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="schemas\htmlml-component.schema.json" Pack="true" PackagePath="schemas\" />
  </ItemGroup>
</Project>
