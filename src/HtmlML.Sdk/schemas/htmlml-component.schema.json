{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://htmlml.dev/schemas/htmlml-component-1.0.json",
  "title": "HtmlML component manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "displayName", "version", "profileVersion", "entryPoint", "assets", "capabilities"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$" },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" },
    "profileVersion": { "const": "1.0" },
    "entryPoint": { "$ref": "#/$defs/path" },
    "assets": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/path" } },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["dom", "css.layout", "canvas.2d", "svg", "input.pointer", "input.keyboard", "input.focus", "clipboard", "host.commands", "host.settings", "host.notifications", "host.network", "host.clipboard", "host.files"]
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mountExport": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" },
        "unmountExport": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" }
      }
    }
  },
  "$defs": {
    "path": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?/)(?!.*\\\\).+$" }
  }
}
