<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <Description>Avalonia control host for packaged HtmlML React and TypeScript components.</Description>
    <PackageId>HtmlML.Sdk.Avalonia</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>htmlml;react;typescript;avalonia;component-host</PackageTags>
    <RepositoryUrl>https://github.com/wieslawsoltes/HtmlML</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\HtmlML.Sdk\HtmlML.Sdk.csproj" />
    <ProjectReference Include="..\HtmlML.Backend.Avalonia\HtmlML.Backend.Avalonia.csproj" />
    <ProjectReference Include="..\JavaScript.Avalonia.ClearScript\JavaScript.Avalonia.ClearScript.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
