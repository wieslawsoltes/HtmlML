<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <Description>Framework-neutral JavaScript runtime, callback, and host contracts for HtmlML.</Description>
    <PackageId>HtmlML.JavaScript</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>html;dom;javascript;runtime;engine</PackageTags>
    <RepositoryUrl>https://github.com/wieslawsoltes/HtmlML</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\HtmlML.Core\HtmlML.Core.csproj" />
  </ItemGroup>
</Project>
