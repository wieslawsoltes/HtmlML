<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <Description>Framework-neutral runtime and backend contracts for HtmlML.</Description>
    <PackageId>HtmlML.Core</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>html;dom;css;javascript;runtime;backend</PackageTags>
    <RepositoryUrl>https://github.com/wieslawsoltes/HtmlML</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>
</Project>
