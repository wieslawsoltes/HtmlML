<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <TrimMode>copyused</TrimMode>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <Description>The complete Avalonia presentation backend for HtmlML.</Description>
    <PackageId>HtmlML.Backend.Avalonia</PackageId>
    <AssemblyName>HtmlML.Backend.Avalonia</AssemblyName>
    <RootNamespace>HtmlML.Backends.Avalonia</RootNamespace>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>html;dom;css;canvas;svg;avalonia;backend</PackageTags>
    <RepositoryUrl>https://github.com/wieslawsoltes/HtmlML</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\HtmlML.Core\HtmlML.Core.csproj" />
    <ProjectReference Include="..\HtmlML.Backend.Abstractions\HtmlML.Backend.Abstractions.csproj" />
    <ProjectReference Include="..\HtmlML.Css\HtmlML.Css.csproj" />
    <ProjectReference Include="..\HtmlML.Dom\HtmlML.Dom.csproj" />
    <ProjectReference Include="..\HtmlML.Graphics\HtmlML.Graphics.csproj" />
    <ProjectReference Include="..\HtmlML.JavaScript\HtmlML.JavaScript.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Skia" />
    <PackageReference Include="AngleSharp" />
    <PackageReference Include="AngleSharp.Css" />
    <PackageReference Include="Svg.Skia" />
  </ItemGroup>
  <ItemGroup>
    <!-- Keep the proven implementation byte-for-byte on the hot path while its
         package ownership moves. -->
    <Compile Include="..\JavaScript.Avalonia\*.cs" />
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="htmlml-backend.json"
          Pack="true"
          PackagePath="\"
          CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
