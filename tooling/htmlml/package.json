{
  "name": "@htmlml/sdk",
  "version": "1.0.0",
  "description": "Bounded TypeScript profile, compatibility checker, and bundler integration for HtmlML",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./runtime.mjs"
    },
    "./profile": "./types/profile.d.ts",
    "./vite": "./vite.mjs",
    "./esbuild": "./esbuild.mjs",
    "./compatibility": "./compatibility.mjs"
  },
  "types": "./types/index.d.ts",
  "bin": {
    "htmlml-check": "./checker.mjs"
  },
  "files": [
    "types",
    "*.mjs",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
