{
  "schemaVersion": 1,
  "baselineId": "htmlml-r0-2026-07-15",
  "description": "Protected pre-extraction behavior, compatibility, coverage and performance lanes.",
  "coverageFloor": "coverage-floor.json",
  "evidenceArtifact": "evidence-summary.json",
  "gates": [
    {
      "id": "release-build",
      "classification": "automated-ci",
      "required": true,
      "command": "dotnet build HtmlML.sln -c Release --no-restore -p:HtmlMlClearScriptNativeRequired=false -p:HtmlMlClearScriptNativeRid=",
      "artifact": "logs/release-build.log"
    },
    {
      "id": "portable-core-contracts",
      "classification": "automated-ci",
      "required": true,
      "command": "dotnet test tests/HtmlML.Core.Tests/HtmlML.Core.Tests.csproj -c Release --no-build --settings coverage-core.runsettings --collect:\"XPlat Code Coverage\"",
      "artifact": "coverage/core/**/coverage.cobertura.xml"
    },
    {
      "id": "architecture-dependencies",
      "classification": "automated-ci",
      "required": true,
      "command": "dotnet test tests/HtmlML.Architecture.Tests/HtmlML.Architecture.Tests.csproj -c Release --no-restore",
      "artifact": "logs/architecture-tests.log"
    },
    {
      "id": "avalonia-headless-net8-net10",
      "classification": "automated-ci",
      "required": true,
      "command": "dotnet test tests/JavaScript.Avalonia.Tests/JavaScript.Avalonia.Tests.csproj -c Release --no-restore --collect:\"XPlat Code Coverage\"",
      "artifact": "coverage/**/coverage.cobertura.xml"
    },
    {
      "id": "wpt-manifest-list",
      "classification": "automated-ci",
      "required": true,
      "command": "dotnet run --project tests/WebPlatformSubset/runner/HtmlML.WebPlatformSubset.Runner.csproj -c Release --no-build -- --selection all --list",
      "artifact": "logs/wpt-list.log"
    },
    {
      "id": "css-performance",
      "classification": "automated-ci",
      "required": true,
      "commands": [
        "probe css-custom-properties --iterations 100",
        "probe css-style-storage --elements 2000 --variants 16 --media-resize"
      ],
      "artifact": "logs/css-*.log"
    },
    {
      "id": "required-wpt",
      "classification": "target-host",
      "required": true,
      "prerequisite": "Reviewed ClearScript V8 native binary for the target RID",
      "command": "dotnet run --project tests/WebPlatformSubset/runner/HtmlML.WebPlatformSubset.Runner.csproj -c Release -- --selection required",
      "artifact": "wpt/results.json"
    },
    {
      "id": "v8-contract-probes",
      "classification": "target-host",
      "required": true,
      "prerequisite": "Reviewed ClearScript V8 native binary for the target RID and pinned React 18.2.0 UMD fixture",
      "commands": [
        "probe v8dom",
        "probe v8canvasboundary",
        "probe v8react",
        "probe v8reactfocus",
        "probe v8iframepointer",
        "probe v8domidentity",
        "probe v8interactioncontracts",
        "probe v8lifecycle",
        "probe v8sharedcache"
      ],
      "artifact": "logs/v8-*.log"
    },
    {
      "id": "native-package-matrix",
      "classification": "blocked-external",
      "required": true,
      "blocker": "Durable ClearScript/V8 fork revisions and reviewed packages do not yet exist for every target RID.",
      "ownerPlan": "docs/architecture/README.md"
    },
    {
      "id": "macos-signing-notarization",
      "classification": "manual-credentialed",
      "required": false,
      "reason": "Requires Apple Developer ID credentials and notarization service access.",
      "ownerPlan": "docs/architecture/README.md"
    }
  ],
  "performanceContracts": [
    {
      "id": "shared-compilation-cache",
      "source": "benchmarks/README.md",
      "reference": "cold/warm compilation, corruption recovery and multi-process contracts",
      "comparison": "semantic and cache-hit results are strict gates"
    }
  ]
}
