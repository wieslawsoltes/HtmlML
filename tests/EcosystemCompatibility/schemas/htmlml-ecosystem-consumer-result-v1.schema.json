{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://htmlml.dev/schemas/htmlml-ecosystem-consumer-result-v1.schema.json",
  "title": "HtmlML ecosystem consumer result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "profile", "recordedAt", "packageLockSha256", "upstreamSourceManifestSha256", "upstreamFiles", "contractFiles", "engines", "consumers"],
  "properties": {
    "schema": { "const": "htmlml-ecosystem-consumer-result-v1" },
    "profile": { "type": "string", "minLength": 1 },
    "recordedAt": { "type": "string", "format": "date-time" },
    "packageLockSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "upstreamSourceManifestSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "upstreamFiles": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" } },
    "contractFiles": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" } },
    "engines": { "type": "object", "additionalProperties": { "$ref": "#/$defs/engine" } },
    "consumers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "package", "version", "stage", "selected", "runnable", "excluded", "harnessBlocked", "upstreamSuite", "engineResults"],
        "properties": {
          "id": { "type": "string" },
          "package": { "type": "string" },
          "version": { "type": "string" },
          "stage": { "enum": ["discovery", "candidate", "required"] },
          "selected": { "type": "integer", "minimum": 0 },
          "runnable": { "type": "integer", "minimum": 0 },
          "excluded": { "type": "array", "items": { "type": "string" } },
          "harnessBlocked": { "type": "array", "items": { "type": "string" } },
          "upstreamSuite": { "type": ["object", "null"] },
          "engineResults": { "type": "object", "additionalProperties": { "$ref": "#/$defs/consumerEngine" } }
        }
      }
    }
  },
  "$defs": {
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "documents", "passed", "failed", "timedOut", "harnessErrors", "subtests", "subtestsPassed", "subtestsFailed", "resultPath"],
      "properties": {
        "identity": { "type": ["string", "null"] },
        "documents": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "timedOut": { "type": "integer", "minimum": 0 },
        "harnessErrors": { "type": "integer", "minimum": 0 },
        "subtests": { "type": "integer", "minimum": 0 },
        "subtestsPassed": { "type": "integer", "minimum": 0 },
        "subtestsFailed": { "type": "integer", "minimum": 0 },
        "resultPath": { "type": "string" }
      }
    },
    "consumerEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documents", "passed", "failed", "subtests", "subtestsPassed", "subtestsFailed"],
      "properties": {
        "documents": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "subtests": { "type": "integer", "minimum": 0 },
        "subtestsPassed": { "type": "integer", "minimum": 0 },
        "subtestsFailed": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
