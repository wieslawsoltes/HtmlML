<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <RuntimeIdentifier Condition="'$(HtmlMlClearScriptNativeRid)' != ''">$(HtmlMlClearScriptNativeRid)</RuntimeIdentifier>
    <HtmlMlClearScriptNativePackageId Condition="'$(HtmlMlClearScriptNativeRid)' != ''">JavaScript.Avalonia.ClearScript.Native.$(HtmlMlClearScriptNativeRid)</HtmlMlClearScriptNativePackageId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.ClearScript.V8" />
    <PackageReference Include="$(HtmlMlClearScriptNativePackageId)"
                      VersionOverride="$(HtmlMlClearScriptNativePackageVersion)"
                      Condition="'$(HtmlMlClearScriptNativePackageId)' != '' and '$(HtmlMlClearScriptNativePackageVersion)' != ''" />
  </ItemGroup>

  <Target Name="ValidateHtmlMlClearScriptNativePackageSmoke" BeforeTargets="PrepareForBuild">
    <Error Condition="'$(HtmlMlClearScriptNativeRid)' == '' or '$(HtmlMlClearScriptNativePackageVersion)' == ''"
           Text="Pass HtmlMlClearScriptNativeRid and HtmlMlClearScriptNativePackageVersion to run the V8 native package smoke." />
  </Target>
</Project>
