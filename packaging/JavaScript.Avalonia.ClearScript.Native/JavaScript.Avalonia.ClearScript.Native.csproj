<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <PackageId Condition="'$(HtmlMlClearScriptNativeRid)' != ''">JavaScript.Avalonia.ClearScript.Native.$(HtmlMlClearScriptNativeRid)</PackageId>
    <PackageId Condition="'$(PackageId)' == ''">JavaScript.Avalonia.ClearScript.Native.Template</PackageId>
    <Description>Reviewed patched ClearScript V8 native runtime for HtmlML trusted same-origin contexts.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <RepositoryUrl>https://github.com/wieslawsoltes/HtmlML</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>avalonia;javascript;v8;clearscript;native</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <HtmlMlClearScriptNativeRequired>true</HtmlMlClearScriptNativeRequired>
    <HtmlMlClearScriptSourceTag>7.5.1</HtmlMlClearScriptSourceTag>
    <HtmlMlClearScriptV8Revision>14.7.173.23</HtmlMlClearScriptV8Revision>
    <HtmlMlClearScriptPatchPath>$(MSBuildThisFileDirectory)..\..\third-party\clearscript-patches\ClearScript-7.5.1-SharedContextSecurityToken.patch</HtmlMlClearScriptPatchPath>
    <HtmlMlClearScriptTypedManagedAbiPatchPath>$(MSBuildThisFileDirectory)..\..\third-party\clearscript-patches\ClearScript-7.5.1-TypedManagedAbi.patch</HtmlMlClearScriptTypedManagedAbiPatchPath>
    <HtmlMlClearScriptPackageMetadataDir>$(MSBuildProjectDirectory)/obj/$(Configuration)/$(TargetFramework)/native-package/</HtmlMlClearScriptPackageMetadataDir>
    <HtmlMlClearScriptNativeHashPath>$(HtmlMlClearScriptPackageMetadataDir)clearscript-native.sha256</HtmlMlClearScriptNativeHashPath>
    <HtmlMlClearScriptPatchHashPath>$(HtmlMlClearScriptPackageMetadataDir)clearscript-patch.sha256</HtmlMlClearScriptPatchHashPath>
    <HtmlMlClearScriptProvenancePath>$(HtmlMlClearScriptPackageMetadataDir)clearscript-provenance.txt</HtmlMlClearScriptProvenancePath>
    <HtmlMlClearScriptRuntimeManifestPath>$(HtmlMlClearScriptPackageMetadataDir)clearscript-native-runtime.json</HtmlMlClearScriptRuntimeManifestPath>
    <HtmlMlClearScriptRuntimePropsPath>$(HtmlMlClearScriptPackageMetadataDir)$(PackageId).props</HtmlMlClearScriptRuntimePropsPath>
  </PropertyGroup>

  <ItemGroup>
    <_HtmlMlReviewedPatch Include="$(HtmlMlClearScriptPatchPath)">
      <PackageFileName>ClearScript-7.5.1-SharedContextSecurityToken.patch</PackageFileName>
    </_HtmlMlReviewedPatch>
    <_HtmlMlReviewedPatch Include="$(HtmlMlClearScriptTypedManagedAbiPatchPath)">
      <PackageFileName>ClearScript-7.5.1-TypedManagedAbi.patch</PackageFileName>
    </_HtmlMlReviewedPatch>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="$(MSBuildThisFileDirectory)..\..\third-party\clearscript-patches\README.md"
          Pack="true" PackagePath="build\clearscript-patches\README.md" />
    <None Include="$(HtmlMlClearScriptPatchPath)"
          Pack="true" PackagePath="build\clearscript-patches\ClearScript-7.5.1-SharedContextSecurityToken.patch" />
    <None Include="$(HtmlMlClearScriptTypedManagedAbiPatchPath)"
          Pack="true" PackagePath="build\clearscript-patches\ClearScript-7.5.1-TypedManagedAbi.patch" />
    <None Include="$(HtmlMlClearScriptNativePath)"
          Pack="true"
          PackagePath="runtimes\$(HtmlMlClearScriptNativeRid)\native\$(HtmlMlClearScriptNativeExpectedFileName)"
          Condition="'$(HtmlMlClearScriptNativePath)' != ''" />
    <None Include="$(HtmlMlClearScriptNativeHashPath)" Pack="true" PackagePath="build\clearscript-native.sha256" />
    <None Include="$(HtmlMlClearScriptPatchHashPath)" Pack="true" PackagePath="build\clearscript-patch.sha256" />
    <None Include="$(HtmlMlClearScriptProvenancePath)" Pack="true" PackagePath="build\clearscript-provenance.txt" />
    <None Include="$(HtmlMlClearScriptRuntimeManifestPath)"
          Pack="true"
          PackagePath="runtimes\$(HtmlMlClearScriptNativeRid)\native\clearscript-native-runtime.json" />
    <None Include="$(HtmlMlClearScriptRuntimePropsPath)"
          Pack="true"
          PackagePath="buildTransitive\$(PackageId).props" />
    <None Include="JavaScript.Avalonia.ClearScript.Native.targets"
          Pack="true"
          PackagePath="buildTransitive\$(PackageId).targets" />
  </ItemGroup>

  <Target Name="PrepareHtmlMlClearScriptNativePackage"
          BeforeTargets="GenerateNuspec"
          DependsOnTargets="ValidateHtmlMlClearScriptV8Native">
    <MakeDir Directories="$(HtmlMlClearScriptPackageMetadataDir)" />
    <GetFileHash Files="$(HtmlMlClearScriptNativePath)" Algorithm="SHA256">
      <Output TaskParameter="Items" ItemName="_HtmlMlNativeHash" />
    </GetFileHash>
    <GetFileHash Files="@(_HtmlMlReviewedPatch)" Algorithm="SHA256">
      <Output TaskParameter="Items" ItemName="_HtmlMlReviewedPatchHash" />
    </GetFileHash>
    <WriteLinesToFile File="$(HtmlMlClearScriptNativeHashPath)"
                      Lines="%(_HtmlMlNativeHash.FileHash)  $(HtmlMlClearScriptNativeExpectedFileName)"
                      Overwrite="true" />
    <WriteLinesToFile File="$(HtmlMlClearScriptPatchHashPath)"
                      Lines="@(_HtmlMlReviewedPatchHash->'%(FileHash)  %(PackageFileName)')"
                      Overwrite="true" />
    <WriteLinesToFile File="$(HtmlMlClearScriptProvenancePath)"
                      Lines="ClearScript source tag: $(HtmlMlClearScriptSourceTag);V8 revision: $(HtmlMlClearScriptV8Revision);RID: $(HtmlMlClearScriptNativeRid)"
                      Overwrite="true" />
    <PropertyGroup>
      <HtmlMlClearScriptNativeHash>@(_HtmlMlNativeHash->'%(FileHash)')</HtmlMlClearScriptNativeHash>
    </PropertyGroup>
    <WriteLinesToFile File="$(HtmlMlClearScriptRuntimeManifestPath)"
                      Lines="{&quot;schemaVersion&quot;:1,&quot;packageVersion&quot;:&quot;$(PackageVersion)&quot;,&quot;runtimeIdentifier&quot;:&quot;$(HtmlMlClearScriptNativeRid)&quot;,&quot;fileName&quot;:&quot;$(HtmlMlClearScriptNativeExpectedFileName)&quot;,&quot;sha256&quot;:&quot;$(HtmlMlClearScriptNativeHash)&quot;,&quot;clearScriptVersion&quot;:&quot;$(HtmlMlClearScriptSourceTag)&quot;,&quot;v8Revision&quot;:&quot;$(HtmlMlClearScriptV8Revision)&quot;,&quot;configuration&quot;:&quot;$(Configuration)&quot;}"
                      Overwrite="true" />
    <WriteLinesToFile File="$(HtmlMlClearScriptRuntimePropsPath)"
                      Lines="&lt;Project&gt;&lt;PropertyGroup&gt;&lt;HtmlMlClearScriptPackagedRid&gt;$(HtmlMlClearScriptNativeRid)&lt;/HtmlMlClearScriptPackagedRid&gt;&lt;HtmlMlClearScriptPackagedFileName&gt;$(HtmlMlClearScriptNativeExpectedFileName)&lt;/HtmlMlClearScriptPackagedFileName&gt;&lt;/PropertyGroup&gt;&lt;/Project&gt;"
                      Overwrite="true" />
  </Target>

  <Import Project="..\..\build\HtmlMlClearScriptV8Native.targets" />
</Project>
