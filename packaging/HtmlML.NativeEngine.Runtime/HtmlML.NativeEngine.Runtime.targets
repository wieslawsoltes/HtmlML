<Project>
  <PropertyGroup>
    <HtmlMlNativeEnginePackageRoot>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\'))</HtmlMlNativeEnginePackageRoot>
    <HtmlMlNativeEnginePackageAsset>$(HtmlMlNativeEnginePackageRoot)runtimes\$(HtmlMlNativeEnginePackagedRid)\native\$(HtmlMlNativeEnginePackagedFileName)</HtmlMlNativeEnginePackageAsset>
    <HtmlMlNativeEnginePackageManifest>$(HtmlMlNativeEnginePackageRoot)runtimes\$(HtmlMlNativeEnginePackagedRid)\native\htmlml-native-runtime.json</HtmlMlNativeEnginePackageManifest>
  </PropertyGroup>

  <ItemGroup Condition="'$(HtmlMlNativeEnginePackagedRid)' != ''">
    <Content Include="$(HtmlMlNativeEnginePackageAsset)"
             Link="$(HtmlMlNativeEnginePackagedFileName)"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest" />
    <Content Include="$(HtmlMlNativeEnginePackageManifest)"
             Link="htmlml-native-runtime.json"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <Target Name="ValidateHtmlMlNativeRuntimePackage"
          BeforeTargets="PrepareForBuild"
          Condition="'$(HtmlMlNativeEnginePackagedRid)' != ''">
    <Error Condition="'$(RuntimeIdentifier)' != '' and '$(RuntimeIdentifier)' != '$(HtmlMlNativeEnginePackagedRid)'"
           Text="HtmlML native runtime package RID '$(HtmlMlNativeEnginePackagedRid)' does not match target RuntimeIdentifier '$(RuntimeIdentifier)'." />
    <Error Condition="!Exists('$(HtmlMlNativeEnginePackageAsset)')"
           Text="HtmlML native runtime package is corrupt; the native asset is missing: $(HtmlMlNativeEnginePackageAsset)" />
    <Error Condition="!Exists('$(HtmlMlNativeEnginePackageManifest)')"
           Text="HtmlML native runtime package is corrupt; its manifest is missing: $(HtmlMlNativeEnginePackageManifest)" />
  </Target>
</Project>
