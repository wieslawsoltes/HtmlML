{
  "schemaVersion": "1.0",
  "profileVersion": "1.0",
  "backend": "HtmlML.Backend.Avalonia",
  "samples": [
    {
      "id": "ComponentHost.Basic",
      "purpose": "Run a JavaScript component without a browser",
      "nonGoals": [
        "General website compatibility",
        "Untrusted-code sandboxing"
      ],
      "requiredProfileVersion": "1.0",
      "backendSupport": {
        "Avalonia": "supported"
      },
      "offlineAssets": true,
      "launchCommand": "dotnet run --project samples/hosts/Avalonia/HtmlML.Sdk.SampleCatalog -- ComponentHost.Basic",
      "expectedInteractions": "mount, click, pixel, disposal",
      "diagnostics": [
        "component lifecycle",
        "compatibility",
        "cache",
        "host bridge"
      ],
      "testCommand": "dotnet run --project tests/HtmlML.Sdk.SampleSmoke",
      "packagingNotes": "Assets are local and declared by htmlml-component.json."
    },
