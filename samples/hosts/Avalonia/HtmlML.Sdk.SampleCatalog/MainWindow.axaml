<Window x:Class="HtmlML.Sdk.SampleCatalog.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1200" Height="760" MinWidth="820" MinHeight="520"
        Title="HtmlML · R5 Sample Catalog">
  <Grid ColumnDefinitions="300,*" RowDefinitions="*,Auto">
    <Border Padding="18" Background="#152238">
      <Grid RowDefinitions="Auto,Auto,*,Auto">
        <StackPanel Spacing="4">
          <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="R5 Sample Catalog" />
          <TextBlock Foreground="#C7D5EA" Text="12 shared component packages" />
        </StackPanel>
        <TextBlock x:Name="PurposeText" Grid.Row="1" Margin="0,18,0,12" Foreground="#8BD3FF" TextWrapping="Wrap" />
        <ListBox x:Name="SampleList" Grid.Row="2" />
        <TextBlock x:Name="InteractionText" Grid.Row="3" Margin="0,12,0,0" Foreground="#C7D5EA" TextWrapping="Wrap" />
      </Grid>
    </Border>
    <Border Grid.Column="1" Padding="18" Background="#F3F6FA">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
          <StackPanel Spacing="2">
            <TextBlock x:Name="SampleTitle" FontSize="24" FontWeight="SemiBold" Foreground="#14213D" Text="Select a sample" />
            <TextBlock x:Name="PackageText" Foreground="#526581" />
          </StackPanel>
          <Button x:Name="ReloadButton" Grid.Column="1" Content="Reload" Click="OnReload" IsEnabled="False" />
        </Grid>
        <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White">
          <Grid>
            <ContentControl x:Name="PreviewPresenter" />
            <Border x:Name="MountErrorPanel" IsVisible="False" Padding="32" Background="#FFF7ED">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="680" Spacing="12">
                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#9A3412" Text="Component runtime unavailable" />
                <TextBlock x:Name="MountErrorText" Foreground="#7C2D12" TextWrapping="Wrap" />
                <TextBlock Foreground="#526581" TextWrapping="Wrap"
                           Text="After preparing the native runtime, rebuild and restart this sample." />
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>
    <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="18,10" Background="#0E1828">
      <TextBlock x:Name="StatusText" MaxHeight="64" Foreground="#C7D5EA" Text="Loading catalog…" TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
