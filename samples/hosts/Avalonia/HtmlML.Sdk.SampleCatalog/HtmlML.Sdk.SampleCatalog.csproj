<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\HtmlML.Sdk\HtmlML.Sdk.csproj" />
    <ProjectReference Include="..\..\..\..\src\HtmlML.Sdk.Avalonia\HtmlML.Sdk.Avalonia.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="..\..\..\components\catalog.json" Link="Catalog\catalog.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\components\**\htmlml-component.json" Link="Catalog\%(RecursiveDir)htmlml-component.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\..\components\**\dist\**\*" Link="Catalog\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <Import Project="..\HtmlMlSampleNative.targets" />
</Project>
