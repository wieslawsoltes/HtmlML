<Window x:Class="HtmlML.Samples.TypeScriptDesktop.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sdk="clr-namespace:HtmlML.Sdk.Avalonia;assembly=HtmlML.Sdk.Avalonia"
        Width="1000" Height="680" MinWidth="680" MinHeight="460"
        Title="HtmlML · TypeScript Desktop">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Padding="20,16" Background="#152238">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White" Text="TypeScript Desktop" />
          <TextBlock Foreground="#C7D5EA" Text="The application surface is owned by a packaged TypeScript component." />
        </StackPanel>
        <Border Grid.Column="1" Padding="10,5" CornerRadius="12" Background="#264E70">
          <TextBlock Foreground="White" Text="Component Profile 1" />
        </Border>
      </Grid>
    </Border>
    <sdk:HtmlMlComponentHost x:Name="PrimaryHost" Grid.Row="1" PackagePath="Component" AutoMount="False" Margin="16" />
    <Border Grid.Row="2" Padding="20,10" Background="#0E1828">
      <TextBlock x:Name="StatusText" Foreground="#C7D5EA" Text="Waiting to mount…" />
    </Border>
  </Grid>
</Window>
