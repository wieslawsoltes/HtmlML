<Window x:Class="HtmlML.Samples.Hybrid.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sdk="clr-namespace:HtmlML.Sdk.Avalonia;assembly=HtmlML.Sdk.Avalonia"
        Width="1100" Height="700" MinWidth="760" MinHeight="480"
        Title="HtmlML · Hybrid React Islands">
  <Grid ColumnDefinitions="230,*" RowDefinitions="*,Auto">
    <Border Padding="20" Background="#152238">
      <StackPanel Spacing="14">
        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Native shell" />
        <TextBlock Foreground="#C7D5EA" TextWrapping="Wrap" Text="Avalonia owns navigation and layout. Two independently mounted JavaScript islands share immutable caches." />
        <Button Content="Native command" Click="OnNativeCommand" />
        <TextBlock x:Name="CommandText" Foreground="#8BD3FF" Text="No command yet" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
    <Grid Grid.Column="1" ColumnDefinitions="*,*" Margin="16">
      <Border Margin="0,0,8,0" BorderBrush="#415A77" BorderThickness="1" CornerRadius="8">
        <sdk:HtmlMlComponentHost x:Name="PrimaryHost" PackagePath="Component" AutoMount="False" Margin="12" />
      </Border>
      <Border Grid.Column="1" Margin="8,0,0,0" BorderBrush="#415A77" BorderThickness="1" CornerRadius="8">
        <sdk:HtmlMlComponentHost x:Name="SecondaryHost" PackagePath="Component" AutoMount="False" Margin="12" />
      </Border>
    </Grid>
    <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="20,10" Background="#0E1828">
      <TextBlock x:Name="StatusText" Foreground="#C7D5EA" Text="Waiting to mount two instances…" />
    </Border>
  </Grid>
</Window>
