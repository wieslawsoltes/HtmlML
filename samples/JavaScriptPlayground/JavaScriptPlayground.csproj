<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <IsPackable>false</IsPackable>
    <DefineConstants>$(DefineConstants);HTMLML_CLEARSCRIPT_V8</DefineConstants>
    <HtmlMlClearScriptNativeRequired>true</HtmlMlClearScriptNativeRequired>
  </PropertyGroup>
  <PropertyGroup>
    <HtmlMlClearScriptNativePath Condition="'$(HtmlMlClearScriptNativePath)' == '' and '$(HTMLML_CLEARSCRIPT_NATIVE)' != ''">$(HTMLML_CLEARSCRIPT_NATIVE)</HtmlMlClearScriptNativePath>
    <HtmlMlClearScriptNativeRid Condition="'$(HtmlMlClearScriptNativeRid)' == '' and '$(HTMLML_CLEARSCRIPT_RID)' != ''">$(HTMLML_CLEARSCRIPT_RID)</HtmlMlClearScriptNativeRid>
    <HtmlMlClearScriptNativeRid Condition="'$(HtmlMlClearScriptNativeRid)' == ''">$(NETCoreSdkRuntimeIdentifier)</HtmlMlClearScriptNativeRid>
    <HtmlMlClearScriptNativeFileName Condition="$([System.String]::Copy('$(HtmlMlClearScriptNativeRid)').StartsWith('win-'))">ClearScriptV8.$(HtmlMlClearScriptNativeRid).dll</HtmlMlClearScriptNativeFileName>
    <HtmlMlClearScriptNativeFileName Condition="$([System.String]::Copy('$(HtmlMlClearScriptNativeRid)').StartsWith('linux-'))">ClearScriptV8.$(HtmlMlClearScriptNativeRid).so</HtmlMlClearScriptNativeFileName>
    <HtmlMlClearScriptNativeFileName Condition="$([System.String]::Copy('$(HtmlMlClearScriptNativeRid)').StartsWith('osx-'))">ClearScriptV8.$(HtmlMlClearScriptNativeRid).dylib</HtmlMlClearScriptNativeFileName>
    <HtmlMlClearScriptNativeCacheRoot Condition="'$(HtmlMlClearScriptNativeCacheRoot)' == ''">$(MSBuildThisFileDirectory)..\..\artifacts\v8-native</HtmlMlClearScriptNativeCacheRoot>
    <HtmlMlClearScriptNativeCacheCandidate>$(HtmlMlClearScriptNativeCacheRoot)\runtimes\$(HtmlMlClearScriptNativeRid)\native\$(HtmlMlClearScriptNativeFileName)</HtmlMlClearScriptNativeCacheCandidate>
    <HtmlMlClearScriptNativeOutputCandidate>$(MSBuildProjectDirectory)\bin\$(Configuration)\$(TargetFramework)\runtimes\$(HtmlMlClearScriptNativeRid)\native\$(HtmlMlClearScriptNativeFileName)</HtmlMlClearScriptNativeOutputCandidate>
    <HtmlMlClearScriptNativePath Condition="'$(HtmlMlClearScriptNativePath)' == '' and Exists('$(HtmlMlClearScriptNativeCacheCandidate)')">$(HtmlMlClearScriptNativeCacheCandidate)</HtmlMlClearScriptNativePath>
    <HtmlMlClearScriptNativePath Condition="'$(HtmlMlClearScriptNativePath)' == '' and Exists('$(HtmlMlClearScriptNativeOutputCandidate)')">$(HtmlMlClearScriptNativeOutputCandidate)</HtmlMlClearScriptNativePath>
    <HtmlMlClearScriptNativeFromOutput Condition="'$(HtmlMlClearScriptNativePath)' == '$(HtmlMlClearScriptNativeOutputCandidate)'">true</HtmlMlClearScriptNativeFromOutput>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Markup.Xaml.Loader" />
    <PackageReference Include="Avalonia.AvaloniaEdit" />
    <PackageReference Include="AvaloniaEdit.TextMate" />
    <PackageReference Condition="'$(Configuration)' == 'Debug'" Include="Avalonia.Diagnostics" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\HtmlML.Backend.Avalonia\HtmlML.Backend.Avalonia.csproj" />
    <ProjectReference Include="..\..\src\JavaScript.Avalonia.ClearScript\JavaScript.Avalonia.ClearScript.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Scripts\**\*.*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <Import Project="..\..\build\HtmlMlClearScriptV8Native.targets" />
</Project>
