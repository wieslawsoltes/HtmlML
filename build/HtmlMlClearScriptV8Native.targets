<Project>
  <PropertyGroup>
    <HtmlMlClearScriptSupportedRids>win-x86;win-x64;win-arm64;linux-x64;linux-arm;linux-arm64;osx-x64;osx-arm64</HtmlMlClearScriptSupportedRids>
    <HtmlMlClearScriptNativeRidSupported Condition="'$(HtmlMlClearScriptNativeRid)' != ''">$([System.String]::Copy(';$(HtmlMlClearScriptSupportedRids);').Contains(';$(HtmlMlClearScriptNativeRid);'))</HtmlMlClearScriptNativeRidSupported>
    <HtmlMlClearScriptNativeExpectedFileName Condition="$([System.String]::Copy('$(HtmlMlClearScriptNativeRid)').StartsWith('win-'))">ClearScriptV8.$(HtmlMlClearScriptNativeRid).dll</HtmlMlClearScriptNativeExpectedFileName>
    <HtmlMlClearScriptNativeExpectedFileName Condition="$([System.String]::Copy('$(HtmlMlClearScriptNativeRid)').StartsWith('linux-'))">ClearScriptV8.$(HtmlMlClearScriptNativeRid).so</HtmlMlClearScriptNativeExpectedFileName>
    <HtmlMlClearScriptNativeExpectedFileName Condition="$([System.String]::Copy('$(HtmlMlClearScriptNativeRid)').StartsWith('osx-'))">ClearScriptV8.$(HtmlMlClearScriptNativeRid).dylib</HtmlMlClearScriptNativeExpectedFileName>
    <HtmlMlClearScriptNativeActualFileName Condition="'$(HtmlMlClearScriptNativePath)' != ''">$([System.IO.Path]::GetFileName('$(HtmlMlClearScriptNativePath)'))</HtmlMlClearScriptNativeActualFileName>
  </PropertyGroup>

  <Target Name="ValidateHtmlMlClearScriptV8Native"
          BeforeTargets="PrepareForBuild"
          Condition="'$(HtmlMlClearScriptNativeRequired)' == 'true' or '$(HtmlMlClearScriptNativePath)' != '' or '$(HtmlMlClearScriptNativeRid)' != ''">
    <Error Condition="'$(HtmlMlClearScriptNativeRequired)' == 'true' and ('$(HtmlMlClearScriptNativePath)' == '' or '$(HtmlMlClearScriptNativeRid)' == '')"
           Text="The HtmlML V8 build requires a reviewed patched ClearScript native library for '$(NETCoreSdkRuntimeIdentifier)'. Build/package it once to populate artifacts/v8-native/runtimes/&lt;rid&gt;/native, set HTMLML_CLEARSCRIPT_NATIVE, or pass HtmlMlClearScriptNativePath." />
    <Error Condition="'$(HtmlMlClearScriptNativePath)' != '' and '$(HtmlMlClearScriptNativeRid)' == ''"
           Text="HtmlMlClearScriptNativePath requires HtmlMlClearScriptNativeRid." />
    <Error Condition="'$(HtmlMlClearScriptNativeRid)' != '' and '$(HtmlMlClearScriptNativePath)' == ''"
           Text="HtmlMlClearScriptNativeRid requires HtmlMlClearScriptNativePath." />
    <Error Condition="'$(HtmlMlClearScriptNativeRid)' != '' and '$(HtmlMlClearScriptNativeRidSupported)' != 'True'"
           Text="Unsupported ClearScript native RID '$(HtmlMlClearScriptNativeRid)'. Supported RIDs: $(HtmlMlClearScriptSupportedRids)." />
    <Error Condition="'$(HtmlMlClearScriptNativePath)' != '' and !Exists('$(HtmlMlClearScriptNativePath)')"
           Text="The configured patched ClearScript native library does not exist: $(HtmlMlClearScriptNativePath)" />
    <Error Condition="'$(HtmlMlClearScriptNativeActualFileName)' != '' and '$(HtmlMlClearScriptNativeActualFileName)' != '$(HtmlMlClearScriptNativeExpectedFileName)'"
           Text="ClearScript native file '$(HtmlMlClearScriptNativeActualFileName)' does not match RID '$(HtmlMlClearScriptNativeRid)'; expected '$(HtmlMlClearScriptNativeExpectedFileName)'." />
  </Target>

  <Target Name="CopyHtmlMlClearScriptV8Native"
          AfterTargets="Build"
          DependsOnTargets="ValidateHtmlMlClearScriptV8Native"
          Condition="'$(HtmlMlClearScriptNativePath)' != '' and '$(HtmlMlClearScriptNativeRid)' != '' and '$(HtmlMlClearScriptNativeFromOutput)' != 'true'">
    <Copy SourceFiles="$(HtmlMlClearScriptNativePath)"
          DestinationFiles="$(OutDir)runtimes/$(HtmlMlClearScriptNativeRid)/native/$(HtmlMlClearScriptNativeExpectedFileName)" />
  </Target>

  <Target Name="PublishHtmlMlClearScriptV8Native"
          AfterTargets="Publish"
          DependsOnTargets="ValidateHtmlMlClearScriptV8Native"
          Condition="'$(HtmlMlClearScriptNativePath)' != '' and '$(HtmlMlClearScriptNativeRid)' != ''">
    <Copy SourceFiles="$(HtmlMlClearScriptNativePath)"
          DestinationFiles="$(PublishDir)runtimes/$(HtmlMlClearScriptNativeRid)/native/$(HtmlMlClearScriptNativeExpectedFileName)" />
  </Target>
</Project>
